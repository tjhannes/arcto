# GoHighLevel API credentials
# Get your Private Integration API Key from:
# GHL → Settings → Integrations → Private Integration
GHL_API_KEY=

# Your GHL Location (sub-account) ID
# Found in GHL → Settings → Business Info → Location ID
GHL_LOCATION_ID=

# Stripe Settings
# Find your Secret key in the Stripe Dashboard (sk_test_...)
STRIPE_SECRET_KEY=

# Stripe Webhook Secret (whsec_...)
# Generated when you create an endpoint in Developers -> Webhooks or run `stripe listen` locally
STRIPE_WEBHOOK_SECRET=
